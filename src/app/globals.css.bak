@import "tailwindcss";

:root {
  --background: #ffffff;
  --surface: #f8f9fa;
  --foreground: #27272a;
  --accent: #d4af37;
}

@theme inline {
  --color-background: var(--background);
  --color-surface: var(--surface);
  --color-foreground: var(--foreground);
  --color-accent: var(--accent);
  
  --font-serif: "Playfair Display", "Noto Serif KR", serif;
  --font-sans: "Pretendard", system-ui, sans-serif;

  --tracking-luxury: 0.05em;
  --shadow-luxury: 0 4px 20px -2px rgba(0, 0, 0, 0.03), 0 2px 10px -1px rgba(0, 0, 0, 0.01);
}

* {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

html,
body {
  max-width: 100vw;
  overflow-x: hidden;
  background-color: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

h1, h2, h3, h4, .font-serif {
  font-family: var(--font-serif);
  letter-spacing: var(--tracking-luxury);
}

.glass {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.luxury-button {
  @apply transition-all duration-500 ease-in-out border border-zinc-200 hover:border-accent hover:text-accent tracking-luxury px-6 py-2 rounded-sm;
}

